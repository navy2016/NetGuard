    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard Next предоставляет простые и расширенные способы блокировки доступа в Интернет без необходимости root-прав. Приложениям и адресам можно индивидуально разрешить или запретить доступ к Wi-Fi и/или мобильному соединению.</string>
