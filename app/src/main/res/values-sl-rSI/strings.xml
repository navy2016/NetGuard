    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard zagotavlja preprost in napreden način za blokiranje interneta - koren ni potreben. Aplikacije in naslovi so lahko posamično dovoljeni ali blokirani pri dostopanju do vašega Wi-Fi in/ali mobilne povezave.</string>
