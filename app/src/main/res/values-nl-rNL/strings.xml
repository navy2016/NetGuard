    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard Next biedt eenvoudige en geavanceerde manieren om internettoegang te blokkeren – zonder root vereist. Apps en adressen kunnen individueel toegang tot je wifi- en/of mobiele verbinding worden verleend of geweigerd.</string>
