    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard Next pakub lihtsaid ja täiustatud viise Interneti-juurdepääsu blokeerimiseks – juurjuurdepääsu pole vaja. Rakendustele ja aadressidele saab eraldi lubada või keelata juurdepääsu teie Wi-Fi- ja/või mobiiliühendusele.</string>
