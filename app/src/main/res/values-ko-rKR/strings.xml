<resources>
    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard Next는 루트 권한 없이 인터넷 접속을 차단하는 간편하고 고급스러운 방법을 제공합니다. 앱 및 주소별로 Wi-Fi 및/또는 모바일 연결에 대한 액세스를 개별적으로 허용하거나 거부할 수 있습니다.</string>
    <string name="app_copyright" translatable="false">Copyright \u00A9 2015–2025 by M. Bokhorst (M66B)</string>
    <string name="app_android">NetGuard는 Android 5.1 이상이 필요합니다.</string>
