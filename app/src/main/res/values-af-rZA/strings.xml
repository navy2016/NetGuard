    <string name="app_name" translatable="false">NetGuard Next</string>
    <string name="app_description">NetGuard Next bied eenvoudige en gevorderde maniere om toegang tot die internet te blokkeer - geen root nodig nie. Programme en adresse kan individueel toegelaat of geweier word vir toegang tot jou Wi-Fi en/of mobiele verbinding.</string>
